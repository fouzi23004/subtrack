# PostgreSQL Database Configuration
#
# Option A: Supabase (or any hosted Postgres) - set DATABASE_URL and the
# SQL_* vars below are ignored. Get this from Supabase dashboard:
# Project Settings > Database > Connection string (use the "Transaction
# pooler", port 6543, for serverless/free hosting deployments).
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
# Option B: Local Postgres (e.g. via docker-compose.yml) - used only when
# DATABASE_URL is not set.
SQL_HOST="localhost"
SQL_USER="your_db_user"
SQL_PASSWORD="your_db_password"
SQL_DB_NAME="subtrack"
SQL_ADMIN_USER="postgres"
SQL_ADMIN_PASSWORD="your_admin_password"

# JWT Secret for authentication
# IMPORTANT: Change this to a random secret in production!
JWT_SECRET="your-secret-key-change-this-in-production"

# Email Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS="true"
EMAIL_NOTIFICATION_TIME="09:00"
EMAIL_NOTIFICATION_TIMEZONE="Africa/Tunis"

# Gmail SMTP Configuration
# IMPORTANT: Use App-Specific Password, not your regular Gmail password
# 1. Enable 2FA in your Google Account
# 2. Go to Security > 2-Step Verification > App passwords
# 3. Generate a new app password for "Mail"
# 4. Use that 16-character password below
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="your-email@gmail.com"
EMAIL_FROM_NAME="SubTrack Notifications"
